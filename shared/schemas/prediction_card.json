{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alea.local/schemas/prediction_card.json",
  "title": "ScorePrediction",
  "type": "object",
  "additionalProperties": false,
  "required": ["match_id", "full_time_score", "half_time_score", "alternative_scores", "direction", "direction_confidence", "opponent_type", "motivation_type", "interaction_summary", "risk_signals", "arguments", "fact_claims", "missing_fields"],
  "properties": {
    "match_id": {"type": "string", "minLength": 1},
    "full_time_score": {"$ref": "#/$defs/score"},
    "half_time_score": {"$ref": "#/$defs/score"},
    "alternative_scores": {"type": "array", "minItems": 1, "maxItems": 2, "items": {"$ref": "#/$defs/score"}},
    "direction": {"type": "string", "enum": ["home", "draw", "away"]},
    "direction_confidence": {"type": "integer", "minimum": 0, "maximum": 100},
    "opponent_type": {"type": "string", "enum": ["A", "B", "C", "U"]},
    "motivation_type": {"type": "string", "enum": ["1", "2", "3", "4", "5", "6", "7", "U"]},
    "interaction_summary": {"type": "string", "minLength": 1, "maxLength": 1000},
    "risk_signals": {"type": "array", "minItems": 2, "maxItems": 3, "items": {"type": "string", "minLength": 1}},
    "arguments": {"type": "array", "items": {"$ref": "#/$defs/argument"}},
    "fact_claims": {"type": "array", "items": {"$ref": "#/$defs/fact_claim"}},
    "missing_fields": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
  },
  "$defs": {
    "score": {
      "type": "object",
      "additionalProperties": false,
      "required": ["home", "away"],
      "properties": {
        "home": {"type": "integer", "minimum": 0, "maximum": 20},
        "away": {"type": "integer", "minimum": 0, "maximum": 20}
      }
    },
    "fact_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_id", "text", "fact_type", "source_record_ids"],
      "properties": {
        "claim_id": {"type": "string", "minLength": 1},
        "text": {"type": "string", "minLength": 1, "maxLength": 500},
        "fact_type": {"type": "string", "enum": ["odds", "form", "standing", "injury", "lineup", "h2h", "weather", "competition_state", "other"]},
        "source_record_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "argument": {
      "type": "object",
      "additionalProperties": false,
      "required": ["argument_id", "text", "fact_claim_ids"],
      "properties": {
        "argument_id": {"type": "string", "minLength": 1},
        "text": {"type": "string", "minLength": 1, "maxLength": 1000},
        "fact_claim_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    }
  }
}
