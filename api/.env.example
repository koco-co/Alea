SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key
SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_AUDIENCE=authenticated
DATABASE_URL_ALEA_API=postgresql://alea_api:password@host:5432/postgres
DATABASE_URL_ALEA_WORKER=postgresql://alea_worker:password@host:5432/postgres
DATABASE_URL_ALEA_DISPATCHER=postgresql://alea_dispatcher:password@host:5432/postgres
DATABASE_URL_ALEA_SCHEDULER=postgresql://alea_scheduler:password@host:5432/postgres
PROVIDER_KEK_V1=64-hex-character-key
REDIS_URL=redis://redis:6379/0
CORS_ALLOWED_ORIGINS=http://localhost

# ALEA-HARDENING-FIXPACK-2026-07-21: explicit runtime and consent configuration
ALEA_PHASE_EXECUTOR_FACTORY=
ALEA_TERMS_VERSION=terms-v1
