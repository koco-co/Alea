{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alea.local/schemas/roundtable.json",
  "title": "RoundtableContract",
  "oneOf": [
    {"$ref": "selection.json#/$defs/selection_nomination"},
    {"$ref": "selection.json#/$defs/selection_debate"},
    {"$ref": "selection.json#/$defs/selection_vote"},
    {"$ref": "prediction_card.json"},
    {"$ref": "debate.json#/$defs/score_debate"},
    {"$ref": "debate.json#/$defs/score_vote"},
    {"$ref": "bet_plan.json#/$defs/bet_proposal"},
    {"$ref": "bet_plan.json#/$defs/bet_debate"},
    {"$ref": "bet_plan.json#/$defs/bet_vote"},
    {"$ref": "review.json"},
    {"$ref": "methodology_review.json"}
  ],
  "$defs": {
    "provider_request": {
      "title": "ProviderRequest",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_id",
        "business_idempotency_key",
        "model_id",
        "model_version",
        "connection_version",
        "identity_prompt_version",
        "core_methodology_version",
        "phase_prompt_version",
        "input_snapshot_id",
        "history_context_version_id",
        "lesson_set_version_id",
        "postmatch_review_context_snapshot_id",
        "methodology_review_context_snapshot_id",
        "output_schema_version",
        "tool_contract_version",
        "generation_parameter_version",
        "timeout_seconds",
        "max_output_tokens"
      ],
      "properties": {
        "request_id": {"type": "string", "format": "uuid"},
        "business_idempotency_key": {"type": "string", "minLength": 1},
        "model_id": {"type": "string", "minLength": 1},
        "model_version": {"type": "string", "minLength": 1},
        "connection_version": {"type": "integer", "minimum": 1},
        "identity_prompt_version": {"type": "integer", "minimum": 1},
        "core_methodology_version": {"type": "integer", "minimum": 1},
        "phase_prompt_version": {"type": "integer", "minimum": 1},
        "input_snapshot_id": {"type": ["string", "null"], "format": "uuid"},
        "history_context_version_id": {"type": ["string", "null"], "format": "uuid"},
        "lesson_set_version_id": {"type": ["string", "null"], "format": "uuid"},
        "postmatch_review_context_snapshot_id": {
          "type": ["string", "null"],
          "format": "uuid"
        },
        "methodology_review_context_snapshot_id": {
          "type": ["string", "null"],
          "format": "uuid"
        },
        "output_schema_version": {"type": "integer", "minimum": 1},
        "tool_contract_version": {"type": "integer", "minimum": 1},
        "generation_parameter_version": {"type": "integer", "minimum": 1},
        "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 900},
        "max_output_tokens": {"type": "integer", "minimum": 1}
      }
    },
    "provider_usage": {
      "title": "ProviderUsage",
      "type": "object",
      "additionalProperties": false,
      "required": ["input_tokens", "output_tokens", "total_tokens"],
      "properties": {
        "input_tokens": {"type": ["integer", "null"], "minimum": 0},
        "output_tokens": {"type": ["integer", "null"], "minimum": 0},
        "total_tokens": {"type": ["integer", "null"], "minimum": 0}
      }
    },
    "provider_error": {
      "title": "ProviderError",
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "code", "message_redacted", "retryable"],
      "properties": {
        "category": {
          "type": "string",
          "enum": [
            "authentication",
            "permission",
            "rate_limit",
            "timeout",
            "refusal",
            "invalid_response",
            "schema_violation",
            "upstream_unavailable",
            "unknown"
          ]
        },
        "code": {"type": ["string", "null"]},
        "message_redacted": {"type": "string", "minLength": 1},
        "retryable": {"type": "boolean"}
      }
    },
    "provider_result": {
      "title": "ProviderResult",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_id",
        "provider_request_id",
        "model_id",
        "data",
        "usage",
        "finish_reason",
        "latency_ms",
        "retry_count",
        "error"
      ],
      "properties": {
        "request_id": {"type": "string", "format": "uuid"},
        "provider_request_id": {"type": ["string", "null"]},
        "model_id": {"type": "string", "minLength": 1},
        "data": {},
        "usage": {"$ref": "#/$defs/provider_usage"},
        "finish_reason": {"type": ["string", "null"]},
        "latency_ms": {"type": "integer", "minimum": 0},
        "retry_count": {"type": "integer", "minimum": 0},
        "error": {"oneOf": [{"$ref": "#/$defs/provider_error"}, {"type": "null"}]}
      }
    }
  }
}
